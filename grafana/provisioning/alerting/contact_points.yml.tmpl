apiVersion: 1

contactPoints:
  - orgId: 1
    name: blacky-notify
    receivers:
      - uid: telegram
        type: telegram
        settings:
          bottoken: "${TELEGRAM_BOT_TOKEN}"
          chatid: "${TELEGRAM_CHAT_ID}"
          message: |
            {{ range .Alerts }}
            🚨 {{ .Labels.severity | toUpper }}: {{ .Annotations.summary }}
            {{ end }}

policies:
  - orgId: 1
    receiver: blacky-notify
    group_by: [alertname, severity]
    group_wait: 30s
    # group_interval kept short: if a notification send fails transiently (e.g. a
    # slow first TLS to api.telegram.org on the T400), the group is retried after
    # this interval rather than 5m — so a brief blip doesn't swallow the alert.
    group_interval: 1m
    repeat_interval: 4h
