# ── Secrets — never commit credentials at any path ────────────────────────────
secrets.yaml
.env

# ── Databases — large, constantly changing, not useful in source control ──────
*.db
*.db-shm
*.db-wal

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Home Assistant ────────────────────────────────────────────────────────────
config/.storage/

# ── Mosquitto ──────────────────────────────────────────────────────────────────
mosquitto/data/
mosquitto/log/
# Password file contains hashed credentials
mosquitto/config/passwd

# ── Node-RED ───────────────────────────────────────────────────────────────────
nodered/data/

# ── ESPHome ────────────────────────────────────────────────────────────────────
# Compiled firmware binaries
esphome/config/.esphome/

# ── Portainer ──────────────────────────────────────────────────────────────────
portainer/data/

# ── Prometheus ─────────────────────────────────────────────────────────────────
prometheus/data/

# ── Grafana ────────────────────────────────────────────────────────────────────
grafana/data/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Python compiled artifacts ──────────────────────────────────────────────────
**/__pycache__/
**/*.pyc
**/*.pyo

# ── Zigbee2MQTT ─────────────────────────────────────────────────────────────
zigbee2mqtt/data/

# ── Generated / security-sensitive — not for git ─────────────────────────────
# fans.yaml: generated by scripts/sync_rf_codes.py; run on blacky to regenerate in place
config/template/fans.yaml
# rf_codes_cache.json: learned RF codes — replay risk if leaked; backed up to HDD via cron
scripts/rf_codes_cache.json

# Node-RED — track flows + settings + lib, ignore runtime/credential files
nodered/data/flows_cred.json
nodered/data/.config.*.json
nodered/data/.sessions.json
nodered/data/node_modules/
nodered/data/lib/node_modules/
nodered/data/.npm/
