mosquitto/config/passwd

# ── Node-RED ───────────────────────────────────────────────────────────────────
nodered/data/

# ── ESPHome ────────────────────────────────────────────────────────────────────
# Compiled firmware binaries
esphome/config/.esphome/

# ── Portainer ──────────────────────────────────────────────────────────────────
portainer/data/

